{
  "name": "apg-garage",
  "version": "1.0.0",
  "private": true,
  "description": "APG Garage — aplicatie service auto pe Cloudflare Workers + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply apg-garage --local",
    "db:migrate": "wrangler d1 migrations apply apg-garage --remote",
    "db:seed:local": "wrangler d1 execute apg-garage --local --file=./migrations/0002_seed.sql",
    "db:seed": "wrangler d1 execute apg-garage --remote --file=./migrations/0002_seed.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.7.2",
    "wrangler": "^3.95.0"
  }
}
